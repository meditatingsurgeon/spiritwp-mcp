{
    "name": "spiritual-agency/spiritwp-mcp",
    "description": "WordPress MCP server — 20 task-shaped tools for AI-assisted site management.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "yoast/wp-test-utils": "^1.2",
        "phpunit/phpunit": "^10.0",
        "squizlabs/php_codesniffer": "^3.7",
        "wp-coding-standards/wpcs": "^3.0"
    },
    "autoload": {},
    "scripts": {
        "test": "phpunit",
        "lint": "phpcs",
        "lint-fix": "phpcbf"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
